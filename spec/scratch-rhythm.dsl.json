{
  "meta": { "name": "Scratch Rhythm Sample", "dslVersion": "1.0" },
  "broadcasts": ["song_start", "spawn_note", "note_judged"],
  "stage": {
    "name": "Stage",
    "isStage": true,
    "tempo": 160,
    "videoTransparency": 50,
    "videoState": "on",
    "textToSpeechLanguage": null,
    "currentCostume": 0,
    "costumes": [
      { "name": "play", "file": "assets/stage/stg_play_bg_v01.png", "dataFormat": "png", "bitmapResolution": 1, "rotationCenterX": 240, "rotationCenterY": 180 }
    ],
    "sounds": [
      { "name": "song_main", "file": "assets/audio/bgm_song_main_160bpm_v01.wav", "dataFormat": "wav", "rate": 44100, "sampleCount": 0, "format": "" }
    ],
    "variables": { "score": 0, "combo": 0, "maxCombo": 0, "fps": 0 },
    "lists": { "laneX": [-90, -30, 30, 90], "judgeLog": [] },
    "procedures": [
      {
        "name": "addScore",
        "params": [ { "name": "amount", "type": "number" } ],
        "warp": true,
        "steps": [
          { "type": "change", "var": "score", "value": { "op": "arg", "name": "amount" } },
          { "type": "change", "var": "combo", "value": 1 },
          { "type": "if",
            "condition": { "op": "gt", "a": { "op": "var", "name": "combo" }, "b": { "op": "var", "name": "maxCombo" } },
            "then": [ { "type": "set", "var": "maxCombo", "value": { "op": "var", "name": "combo" } } ]
          }
        ]
      }
    ],
    "scripts": [
      {
        "event": { "type": "green_flag" },
        "steps": [
          { "type": "set", "var": "score", "value": 0 },
          { "type": "set", "var": "combo", "value": 0 },
          { "type": "set", "var": "maxCombo", "value": 0 },
          { "type": "showVar", "var": "score" },
          { "type": "showVar", "var": "combo" },
          { "type": "broadcastAndWait", "name": "song_start" },
          { "type": "broadcast", "name": "spawn_note" }
        ]
      },
      {
        "event": { "type": "receive", "name": "song_start" },
        "steps": [
          { "type": "playSound", "sound": "song_main" },
          { "type": "resetTimer" }
        ]
      },
      {
        "event": { "type": "receive", "name": "note_judged" },
        "steps": [
          { "type": "call", "proc": "addScore", "args": { "amount": 300 } }
        ]
      }
    ]
  },
  "sprites": [
    {
      "name": "Note",
      "isStage": false,
      "x": 0, "y": 180, "size": 100, "direction": 90,
      "visible": false, "draggable": false, "rotationStyle": "all around",
      "currentCostume": 0,
      "costumes": [
        { "name": "tap_blue", "file": "assets/sprites/spr_note_tap_blue_v01.png", "dataFormat": "png", "bitmapResolution": 1, "rotationCenterX": 24, "rotationCenterY": 24 }
      ],
      "sounds": [
        { "name": "hit", "file": "assets/audio/sfx_hit_perfect_v01.wav", "dataFormat": "wav", "rate": 44100, "sampleCount": 0, "format": "" }
      ],
      "variables": { "lane": 0, "speed": 4 },
      "lists": {},
      "procedures": [],
      "scripts": [
        {
          "event": { "type": "receive", "name": "spawn_note" },
          "steps": [
            { "type": "repeat", "times": 4, "steps": [
              { "type": "set", "var": "lane", "value": { "op": "random", "from": 0, "to": 3 } },
              { "type": "createClone", "target": "myself" },
              { "type": "wait", "secs": 0.35 }
            ] }
          ]
        },
        {
          "event": { "type": "clone_start" },
          "steps": [
            { "type": "setX", "x": { "op": "listGet", "list": "laneX", "index": { "op": "add", "a": { "op": "var", "name": "lane" }, "b": 1 } } },
            { "type": "setY", "y": 180 },
            { "type": "show" },
            { "type": "forever", "steps": [
              { "type": "changeY", "value": { "op": "mul", "a": { "op": "var", "name": "speed" }, "b": -1 } },
              { "type": "if",
                "condition": { "op": "lt", "a": { "op": "yPos" }, "b": -180 },
                "then": [ { "type": "deleteClone" } ]
              }
            ] }
          ]
        },
        {
          "event": { "type": "key_pressed", "key": "space" },
          "steps": [
            { "type": "playSound", "sound": "hit" }
          ]
        }
      ]
    }
  ]
}
