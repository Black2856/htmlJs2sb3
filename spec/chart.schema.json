{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://local/scratch-rhythm/chart.schema.json",
  "title": "Scratch Rhythm Chart",
  "type": "object",
  "required": ["version", "meta", "audio", "timing", "notes"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "meta": {
      "type": "object",
      "required": ["title", "bpm", "offsetMs", "lanes"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "artist": { "type": "string" },
        "bpm": { "type": "number", "exclusiveMinimum": 0 },
        "offsetMs": { "type": "number" },
        "lanes": { "type": "integer", "minimum": 1, "maximum": 8 }
      },
      "additionalProperties": true
    },
    "audio": {
      "type": "object",
      "required": ["file"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "previewStartMs": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "timing": {
      "type": "object",
      "properties": {
        "perfectMs": { "type": "number", "exclusiveMinimum": 0 },
        "greatMs": { "type": "number", "exclusiveMinimum": 0 },
        "goodMs": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "timeMs", "lane", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "timeMs": { "type": "number", "minimum": 0 },
          "lane": { "type": "integer", "minimum": 0 },
          "type": { "type": "string", "enum": ["tap", "hold", "flick", "slide"] },
          "endTimeMs": { "type": "number", "minimum": 0 },
          "sfx": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
